---
// === MACSOFT AUDIT ===
// Old palette found: #0f172a, #1e293b, #2563eb, #3b82f6, #1d4ed8, #10b981,
//   #f59e0b, #f8fafc, #f1f5f9, #e2e8f0, #cbd5e1, #94a3b8, #64748b, #475569,
//   #334155, #667eea, #764ba2, #1e3a8a, #06b6d4, #0e7490, #25d366
// Sections removed: "Nuestro Equipo" (fake placeholder bios), fake testimonials (DO/CT/GI),
//   "Casos de Éxito" (no real data), portfolio page (empty), "Oferta Especial" urgency bar,
//   exit intent modal, Alpine.js + Ionicons CDN
// Components consolidated: 6 duplicate IntersectionObserver scripts → ScrollReveal.jsx,
//   duplicate keyframes → globals.css, duplicate button styles → Button.jsx + globals.css,
//   tailwind.config.js (duplicate) removed
// Key issues fixed: All icons → lucide-react / @phosphor-icons/react, all text → content.js,
//   all colors → CSS variables, personal gmail removed, fake stats eliminated
//
// ARCHITECTURE: Multi-page site.
//   /          → Landing (Hero + Products + Services + Sectors + HowWeWork + WhyMacSoft + Clients + CTA)
//   /servicios → Productos propios + Servicios a medida detallados
//   /proceso   → Metodología completa + Stack tecnológico
//   /sectores  → Tarjetas por industria con problemas que resuelve
//   /clientes  → Clientes reales con descripción de proyectos
//   /contacto  → Información de contacto + WhatsApp CTA

import Layout from '../layouts/Layout.astro'
import Navbar from '../components/layout/Navbar'
import Footer from '../components/layout/Footer'
import Hero from '../components/sections/Hero'
import FeaturedProducts from '../components/sections/FeaturedProducts'
import Services from '../components/sections/Services'
import Sectors from '../components/sections/Sectors'
import HowWeWork from '../components/sections/HowWeWork'
import WhyMacSoft from '../components/sections/WhyMacSoft'
import ClientsPreview from '../components/sections/ClientsPreview'
import FinalCTA from '../components/sections/FinalCTA'
---

<Layout
  title="MacSoft — Software a tu medida | Chiclayo, Perú"
  description="MacSoft construye software 100% personalizado para tu negocio. Sistemas de gestión, plataformas web, apps móviles, integraciones y automatización. Chiclayo, Perú."
>
  <Navbar activePath="/" client:load />
  <main style="padding-top: 68px;">
    <Hero client:load />
    <FeaturedProducts client:visible />
    <Services client:visible />
    <Sectors client:visible />
    <HowWeWork client:visible />
    <WhyMacSoft client:visible />
    <ClientsPreview client:visible />
    <FinalCTA client:visible />
  </main>
  <Footer client:load />
</Layout>
