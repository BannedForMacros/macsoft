---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/layout/Navbar'
import Footer from '../components/layout/Footer'
import PageHero from '../components/sections/PageHero'
import ProcesoPage from '../components/sections/ProcesoPage'
---

<Layout
  title="Cómo desarrollamos tu software | Metodología MacSoft — Chiclayo, Perú"
  description="Proceso claro en 4 etapas: diagnóstico, diseño, desarrollo iterativo y lanzamiento. Sin intermediarios. MacSoft, empresa de software en Chiclayo, Perú."
  canonicalPath="/proceso"
>
  <Navbar activePath="/proceso" client:load />
  <main style="padding-top: 68px;">
    <PageHero
      eyebrow="Nuestra metodología"
      title="Cómo trabajamos"
      subtitle="Transparencia total desde el primer día. Quien te atiende es quien construye tu software."
      client:load
    />
    <ProcesoPage client:visible />
  </main>
  <Footer client:load />
</Layout>
