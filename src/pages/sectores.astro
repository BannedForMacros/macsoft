---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/layout/Navbar'
import Footer from '../components/layout/Footer'
import PageHero from '../components/sections/PageHero'
import SectoresPage from '../components/sections/SectoresPage'
---

<Layout
  title="Software para Restaurantes, Salud, Legal, Logística y más | MacSoft Chiclayo"
  description="Sistemas a medida para restaurantes, clínicas, estudios legales, distribuidoras, talleres, cooperativas y más. MacSoft digitaliza cualquier proceso en Perú."
  canonicalPath="/sectores"
>
  <Navbar activePath="/sectores" client:load />
  <main style="padding-top: 68px;">
    <PageHero
      eyebrow="Industrias"
      title="Sectores que atendemos"
      subtitle="Si tu negocio tiene un proceso, nosotros lo digitalizamos. Sin límite de sector."
      client:load
    />
    <SectoresPage client:visible />
  </main>
  <Footer client:load />
</Layout>
