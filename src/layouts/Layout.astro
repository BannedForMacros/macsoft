---
import '../styles/globals.css'

interface Props {
  title?: string
  description?: string
}
const {
  title = 'MacSoft — Software a tu medida | Chiclayo, Perú',
  description = 'MacSoft construye software 100% personalizado para tu negocio: sistemas de gestión, plataformas web, apps móviles e integraciones. Chiclayo, Perú.',
} = Astro.props
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0F2D5C" />
    <link rel="icon" type="image/svg+xml" href="/macsoft-isotipo.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
